# ---------------------------------------------------------------------------
# docker-compose environment. Copy to .env and edit. NEVER commit the real .env.
# These values feed both the compose file and the policyd service (env_file).
# ---------------------------------------------------------------------------

# --- Database ---
DB_NAME=policyd
DB_USER=policyd
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# --- Redis ---
REDIS_MASTER_NAME=ratemaster

# --- Decision behaviour ---
DEFER_CODE=451
DEFER_TEXT=4.7.1 Rate limit exceeded, please retry later
REJECT_CODE=554
REJECT_TEXT=5.7.1 Sending temporarily disabled (suspected abuse), contact support
FAIL_ACTION=DUNNO

# --- Defaults / warm-up ---
DEFAULT_TIER=default
WARMUP_TIER=warmup
WARMUP_DAYS=3
PER_MESSAGE_RCPT_CAP=100
# How the per-minute/hour/day/month quotas are counted:
#   recipients (default, same as the classic daemon) = a message to N recipients
#              consumes N of the quota.
#   messages   = each email consumes 1 regardless of recipients; per-message
#              fan-out is then bounded only by PER_MESSAGE_RCPT_CAP / tier maxRcptMsg.
RATE_COUNT_MODE=recipients

# --- Anomaly detection (auto-suspend + hard bounce on abnormal sending) ---
ANOMALY_ENABLED=true
ANOMALY_MODE=observe          # observe (detect+alert only) | enforce (also suspend)
ANOMALY_BURST_PER_MIN=120
ANOMALY_DISTINCT_RCPT_PER_MIN=80
ANOMALY_OFFHOURS_START=1
ANOMALY_OFFHOURS_END=5
ANOMALY_OFFHOURS_PER_MIN=40
ANOMALY_FLAGS_TO_SUSPEND=3
ANOMALY_WINDOW_SEC=600
TZ=Asia/Ho_Chi_Minh

# --- Admin API auth (the UI login) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_strong_admin_password
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_TTL=8h

# --- Feedback loop (B): MTA delivery-outcome ingest -> bounce/spam-rate ---
FEEDBACK_TOKEN=change_me_feedback_shared_secret
BOUNCE_RATE_MIN_SAMPLE=20
BOUNCE_RATE_THRESHOLD=0.3
FEEDBACK_WINDOW_HOURS=24

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=
ALERT_MIN_INTERVAL_SEC=300
# Alert when a sender exceeds ITS TIER's hourly limit (perHour of the resolved
# tier, e.g. default=200, business=1000, vip=5000 - the threshold matches each
# sender's tier, not a fixed number). Off by default. Fires ONCE per sender per
# clock-hour via Telegram/webhook.
NOTIFY_OVER_HOURLY=false

# --- Grafana ---
GRAFANA_PASSWORD=change_me_grafana_password

# --- Host port mapping (what gets published on the host) ---
# Only the policy port is reachable on the network; everything else binds to
# 127.0.0.1 (loopback) and is reached via SSH tunnel or a TLS reverse proxy.
# Change these if a port already clashes with another app on the host.
POLICY_LISTEN=0.0.0.0      # set to a LAN IP (e.g. 10.0.0.50) or 127.0.0.1 to narrow exposure
POLICY_PORT=10032          # host port for the Postfix policy protocol
UI_PORT=8080               # loopback host port for the admin UI/API
STATS_PORT=8404            # loopback host port for HAProxy stats
PROMETHEUS_PORT=9090       # loopback host port for Prometheus
GRAFANA_PORT=3000          # loopback host port for Grafana

# --- Ops ---
LOG_LEVEL=info
EVENT_SAMPLE_OK=0
