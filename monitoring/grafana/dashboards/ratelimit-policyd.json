      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (reason) (rate(policyd_anomaly_flags_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "Suspensions, Latency & Runtime",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Suspensions rate",
      "description": "rate(policyd_suspensions_total[15m])",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
