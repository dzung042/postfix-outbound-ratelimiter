# ---------------------------------------------------------------------------
# ratelimit-policyd-svc configuration (copy to .env, never commit real secrets)
# ---------------------------------------------------------------------------

# --- Listeners ---
POLICY_PORT=10032           # Postfix policy-delegation TCP port
POLICY_BIND=0.0.0.0         # bind inside container; expose only on internal net
HTTP_PORT=8080              # admin REST API + static UI
METRICS_PORT=9100           # Prometheus /metrics + /healthz

# --- Trust / allowlist for the policy protocol (no auth in the protocol) ---
# Comma-separated IPs/CIDRs allowed to query the policy port. Empty = allow all
# (rely on network/firewall/HAProxy instead). HAProxy forwards real MTA IPs.
POLICY_ALLOW_CIDRS=10.0.0.0/8,127.0.0.1/32

# --- Redis Sentinel (counters + pub/sub) ---
# Provide sentinel host:port pairs. The service resolves the primary via them.
REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
REDIS_MASTER_NAME=ratemaster
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=rl:
# Fallback single-node (used only if REDIS_SENTINELS is empty), e.g. local dev:
REDIS_URL=

# --- Config + audit database (MySQL/MariaDB) ---
DATABASE_URL=mysql://policyd:CHANGE_ME@db:3306/policyd

# --- Decision behaviour ---
# Soft over-quota (hour/day/month): defer with a 4xx so the MTA retries.
DEFER_CODE=451
DEFER_TEXT=4.7.1 Rate limit exceeded, please retry later
# Hard block (suspended / confirmed abuse): 5xx so the message bounces.
REJECT_CODE=554
REJECT_TEXT=5.7.1 Sending temporarily disabled (suspected abuse), contact support
# What to answer when Redis/DB is unavailable: DUNNO = fail-open (recommended).
FAIL_ACTION=DUNNO

# --- Defaults / warm-up (applied when no tier/domain/sender override matches) ---
DEFAULT_TIER=default
WARMUP_TIER=warmup
WARMUP_DAYS=3               # new senders stay on the warmup tier this many days
PER_MESSAGE_RCPT_CAP=100    # hard cap on recipients per single message

# --- Anomaly detection (abnormal sending -> suspend + hard bounce) ---
ANOMALY_ENABLED=true
# observe = detect + alert + risk score but DO NOT suspend (safe rollout, tune first)
# enforce = also auto-suspend + hard bounce on threshold
ANOMALY_MODE=observe
ANOMALY_BURST_PER_MIN=120         # > this many recipients in 60s = velocity flag
ANOMALY_DISTINCT_RCPT_PER_MIN=80  # fan-out: distinct recipients/min threshold
ANOMALY_OFFHOURS_START=1          # local hour (inclusive) off-hours window start
ANOMALY_OFFHOURS_END=5            # local hour (inclusive) off-hours window end
ANOMALY_OFFHOURS_PER_MIN=40       # tighter velocity during off-hours
ANOMALY_FLAGS_TO_SUSPEND=3        # this many flags within the window -> suspend
ANOMALY_WINDOW_SEC=600            # rolling window for counting flags
TZ=Asia/Ho_Chi_Minh

# --- Admin API auth ---
ADMIN_USER=admin
# bcrypt-style not used; provide a strong password and a JWT secret.
ADMIN_PASSWORD=CHANGE_ME_STRONG
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_TTL=8h

# --- Feedback loop (B): MTA delivery-outcome ingest -> bounce/spam-rate ---
# Shared secret the log shipper sends as X-Feedback-Token. Empty = ingest closed.
FEEDBACK_TOKEN=
BOUNCE_RATE_MIN_SAMPLE=20      # need this many sends before judging a sender
BOUNCE_RATE_THRESHOLD=0.3      # (bounce+spam)/sent >= this -> flag/suspend
FEEDBACK_WINDOW_HOURS=24       # rolling window for the rate

# --- Notifications (alerts on suspend / redis-down / spikes) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Generic webhook (e.g. a chat/automation flow -> Telegram/Slack). POSTed a JSON payload.
ALERT_WEBHOOK_URL=
ALERT_MIN_INTERVAL_SEC=300   # de-dupe: min seconds between identical alerts

# --- Ops ---
RUN_MIGRATIONS=true
RUN_SEED=false
LOG_LEVEL=info               # debug|info|warn|error
EVENT_SAMPLE_OK=0            # 0 = do not log every allowed mail (only over-quota)
